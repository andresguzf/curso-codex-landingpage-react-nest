generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Course {
  id           Int      @id @default(autoincrement())
  slug         String   @unique
  title        String
  category     String
  description  String
  image_url    String?
  hours        Float
  rating       Float
  price        Float
  best_sellers Boolean @default(false)
  tagsJson     String   @default("[]")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
}
