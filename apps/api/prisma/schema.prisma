generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Course {
  id         Int     @id @default(autoincrement())
  slug       String  @unique
  title      String
  category   String
  duration   String
  rating     Float
  price      Int
  visual     String
  best_sellers Boolean @default(false)
  tagsJson   String
  searchText String @default("")
}
